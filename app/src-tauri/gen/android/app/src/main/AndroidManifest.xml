<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Seal-style download-progress notifications (Android 13+ runtime prompt). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Keep background download-progress polling alive when the screen is off:
         request an exemption from battery optimizations (prompted on launch). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- DownloadService keeps the process alive while a download runs so its
         progress notification stays live through to "complete". Without a
         foreground service the share target's polling thread was reclaimed with
         the (already finished) activity's process. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.orca_app"
        android:usesCleartextTraffic="${usesCleartextTraffic}">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:launchMode="singleTask"
            android:label="@string/main_activity_title"
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Dedicated "Quick Download" share target (mirrors Seal's
             QuickDownloadActivity). The system chooser can't launch our
             singleTask launcher MainActivity via startActivityAsCaller on
             HyperOS/MIUI (ActivityNotFoundException), so shares went nowhere.
             This singleInstance, excluded-from-recents activity launches
             cleanly and forwards the shared link into MainActivity. -->
        <!-- NOTE: intentionally NO translucent/transparent theme. HyperOS/MIUI's
             background-activity-launch guard denies a share-sheet
             (startActivityAsCaller) launch of a TRANSLUCENT activity as an
             overlay-phishing attempt — AMS returns result -92 and the chooser
             throws ActivityNotFoundException, so the X share silently vanished
             (ShareActivity never ran: no toast, no POST, no cookie). Seal's
             working QuickDownloadActivity is opaque (no theme override); we match
             it. ShareActivity finishes in onCreate(), so the opaque window that
             briefly appears is momentary. -->
        <activity
            android:name=".ShareActivity"
            android:exported="true"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true">
            <intent-filter android:label="@string/share_target_label">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter android:label="@string/share_target_label">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
                <data android:mimeType="video/*" />
                <data android:mimeType="audio/*" />
            </intent-filter>
        </activity>

        <!-- Owns download-progress notifications: polls the backend for status
             and updates one notification per item in place, deep-linking into
             the matching row on tap. dataSync is the correct type — it mirrors
             remote download state rather than doing local media playback. -->
        <service
            android:name=".DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <provider
          android:name="androidx.core.content.FileProvider"
          android:authorities="${applicationId}.fileprovider"
          android:exported="false"
          android:grantUriPermissions="true">
          <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
