{
  "name": "whale-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript sources for the Whale web UI. Built (bundled + minified) into ../web, which the Rust backend embeds and the Tauri app ships verbatim.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "check": "tsc --noEmit && eslint src && node build.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "eslint-plugin-security": "^3.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  }
}
